# 🌍 Configuration de production pour Diaspomoney

# ===========================================
# Configuration de l'application
# ===========================================

# Host et port de l'application
HOSTNAME=0.0.0.0
PORT=3000

# ===========================================
# Configuration Let's Encrypt
# ===========================================

# Email pour les certificats SSL (OBLIGATOIRE)
LETSENCRYPT_EMAIL=contact@diaspomoney.fr

# ===========================================
# Configuration MongoDB
# ===========================================

# Credentials MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin123
MONGO_INITDB_DATABASE=diaspomoney

# URL de connexion MongoDB
MONGODB_URL=mongodb://diaspomoney_user:diaspomoney_pass@mongodb:27017/diaspomoney

# ===========================================
# Configuration de sécurité
# ===========================================

# Clé secrète pour JWT (GÉNÉRER UNE NOUVELLE CLÉ EN PRODUCTION)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Clé de chiffrement (GÉNÉRER UNE NOUVELLE CLÉ EN PRODUCTION)
ENCRYPTION_KEY=your-encryption-key-change-this-in-production

# ===========================================
# Configuration des domaines
# ===========================================

# Domaines de production (modifier selon votre configuration)
APP_DOMAIN=app.diaspomoney.fr
DASHBOARD_DOMAIN=dashboard.diaspomoney.fr
MONGO_DOMAIN=mongo.diaspomoney.fr

# ===========================================
# Configuration de monitoring
# ===========================================

# Prometheus
PROMETHEUS_RETENTION_TIME=15d

# Grafana
GRAFANA_ADMIN_PASSWORD=admin123

# ===========================================
# Configuration de logs
# ===========================================

# Niveau de log (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# ===========================================
# Configuration de performance
# ===========================================

# Nombre de workers Node.js
NODE_ENV=production

# ===========================================
# Instructions d'utilisation
# ===========================================

# 1. Copiez ce fichier vers .env
#    cp env.production.example .env

# 2. Modifiez les valeurs selon votre environnement
#    - LETSENCRYPT_EMAIL: Votre email pour Let's Encrypt
#    - JWT_SECRET: Générez une clé secrète forte
#    - ENCRYPTION_KEY: Générez une clé de chiffrement
#    - Domaines: Modifiez selon votre configuration DNS

# 3. Lancez le déploiement
#    ./scripts/deploy-production.sh

# ===========================================
# Génération de clés sécurisées
# ===========================================

# Pour générer des clés sécurisées :
# JWT_SECRET=$(openssl rand -base64 32)
# ENCRYPTION_KEY=$(openssl rand -base64 32)
